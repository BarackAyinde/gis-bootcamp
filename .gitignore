# .gitignore for GIS Bootcamp

# Virtual environment
venv/
ENV/
env/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Data files (large)
data/*.gpkg
data/*.shp
data/*.shx
data/*.dbf
data/*.prj
data/*.tif
data/*.tiff
data/*.geojson
data/*.json

# Test outputs
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log
